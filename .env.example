# Database (#02 — Prisma + Postgres)
#
# Dev local com Docker (recomendado): rode `npm run db:up` e use a URL abaixo.
# Producao: Neon Postgres via Vercel Marketplace ou outro provider.
DATABASE_URL="postgresql://meus_audios:meus_audios_dev@localhost:5432/meus_audios?schema=public"

# Storage (#03 — Vercel Blob)
BLOB_READ_WRITE_TOKEN=""

# Auth (#04 — NextAuth v5 / Auth.js)
#
# Gere o secret com: openssl rand -base64 32
# AUTH_URL nao e necessario na Vercel (auto-detectado); preencher localmente.
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"

# Auth providers (#09 — Google OAuth)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI (#28-#33 — Whisper + análises)
OPENAI_API_KEY=""
